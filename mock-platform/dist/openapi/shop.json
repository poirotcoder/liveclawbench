        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "string"
                    },
                    "service": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/__mock_sentinel__/shop": {
      "get": {
        "summary": "Binary isolation probe",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "summary": "List products",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "default": ""
            },
            "required": false,
            "name": "q",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "similarity",
                "price_asc",
                "price_desc",
                "rating"
              ],
              "default": "similarity"
            },
            "required": false,
            "name": "sort",
            "in": "query"
          },
          {
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "required": false,
            "name": "page",
            "in": "query"
          },
          {
            "schema": {
              "type": [
                "number",
                "null"
              ]
            },
            "required": false,
            "name": "min_price",
            "in": "query"
          },
          {
            "schema": {
              "type": [
                "number",
                "null"
              ]
            },
            "required": false,
            "name": "max_price",
            "in": "query"
          },
          {
            "schema": {
              "type": [
                "number",
                "null"
              ]
            },
            "required": false,
            "name": "min_rating",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "price": {
                            "type": "number"
                          },
                          "rating": {
                            "type": "number"
                          },
                          "rating_count": {
                            "type": "string"
                          },
                          "image_url": {
                            "type": "string"
                          },
                          "sponsored": {
                            "type": "boolean"
                          },
                          "best_seller": {
                            "type": "boolean"
                          },
                          "overall_pick": {
                            "type": "boolean"
                          },
                          "limited_time": {
                            "type": "boolean"
                          },
                          "discounted": {
                            "type": "boolean"
                          },
                          "low_stock": {
                            "type": "boolean"
                          },
                          "stock_quantity": {
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "title",
                          "price",
                          "rating",
                          "rating_count",
                          "image_url"
                        ]
                      }
                    },
                    "total_products": {
                      "type": "number"
                    },
                    "total_pages": {
                      "type": "number"
                    },
                    "current_page": {
                      "type": "number"
                    },
                    "products_per_page": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "products",
                    "total_products",
                    "total_pages",
                    "current_page",
                    "products_per_page"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
