帮我把codex调通，现在已经在config文件里面把可以用的base url和api key写进去了，直到你能够通过调用/humanize:codex并成功收到消息为止

export OPENAI_BASE_URL="http://109.22.128.154:8000/v1"
export OPENAI_API_KEY="sk-ai-tf-beijing"
export OPENAI_MODEL="glm-5-fp8"

openai api completions.create \
  -m $OPENAI_MODEL \
  -p "def fibonacci(n):" \
  --max-tokens 50

/humanize:gen-plan —discussion --input Health_mock/.humanize/drafts/health_spec/*.md --output Health_mock/.humanize/plans/                                                                                                                                                                          
