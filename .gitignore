jobs-migrated/
jobs-baseline/
jobs-migrated-round6/
jobs-baseline-round6/
jobs-migrated-round7/
jobs-*-round*/
jobs-round11-*/
logs/
*.log

# Harbor parity comparison tables (generated verification artifacts)
harbor-parity-*.md

# Evidence directories (generated verification artifacts)
evidence-round*/

# Local run scripts (not tracked)
run_*.sh

# SSH keys — never commit (root-only to avoid matching id_mapping.csv etc.)
/*.pem
/id_*
/id_*.pub

# Node.js dependencies
**/node_modules/

# Flask instance folders (SQLite runtime databases)
**/instance/

# Local Git worktrees used by code agents
.worktrees/

# Claude Code worktrees and session data
.claude/

# Playwright MCP session logs
.playwright-mcp/

# Shell redirect artifacts (accidental `>&amp;` typos create files named `amp`)
amp

# Humanize plugin state (drafts, plans, plan QA, bitlesson, config)
.humanize/

# Superpowers design specs (development artifacts, not maintained docs)
docs/superpowers/

# Local venv (symlink to main repo)
.venv
.venv/

tasks/**/airline-app/frontend/dist/
